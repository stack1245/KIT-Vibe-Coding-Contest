# App
PORT=3000
APP_BASE_URL=http://localhost:3000
TRUST_PROXY_HEADERS=false
NEXT_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1
SESSION_SECRET=replace-with-a-long-random-secret
DEPLOYMENT_VERSION=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_TOKEN_ENCRYPTION_KEY=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback
GITHUB_SCOPE=read:user user:email

# Admin
ADMIN_EMAILS=admin@example.com

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Phase Vuln Coach <no-reply@example.com>

# Upload screening
UPLOAD_SCREENING_MODE=hybrid
UPLOAD_CODEX_MODEL=gpt-5.4
UPLOAD_CODEX_TIMEOUT_MS=20000
UPLOAD_TOTAL_LIMIT_BYTES=2147483648
UPLOAD_MAX_FILE_BYTES=268435456
MAX_SAFE_ARCHIVE_ENTRY_COUNT=2000
MAX_SAFE_ARCHIVE_TOTAL_UNCOMPRESSED_BYTES=536870912
